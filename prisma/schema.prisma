// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ユーザー管理
model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  name              String?
  role              UserRole           @default(USER)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relations
  contents          Content[]
  socialPosts       SocialPost[]
  socialAccounts    SocialAccount[]
  contentVersions   ContentVersion[]
  analyticsData     AnalyticsData[]
  n8nWorkflows      N8nWorkflow[]
  teamMembers       TeamMember[]
  auditLogs         AuditLog[]
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
  USER
}

// チーム管理
model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relations
  members     TeamMember[]
  contents    Content[]
  socialPosts SocialPost[]
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  @@unique([userId, teamId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

// SNSアカウント接続情報
model SocialAccount {
  id               String          @id @default(cuid())
  userId           String
  platform         SocialPlatform
  platformUserId   String
  username         String?
  accessToken      String          @db.Text
  refreshToken     String?         @db.Text
  accessTokenSecret String?         @db.Text // Twitter用
  apiKey           String?         @db.Text // Twitter API Key
  apiSecret        String?         @db.Text // Twitter API Secret
  tokenExpiresAt   DateTime?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialPosts      SocialPost[]

  @@unique([userId, platform])
  @@index([platform, isActive])
}

enum SocialPlatform {
  TWITTER
  INSTAGRAM
  TIKTOK
}

// コンテンツ管理
model Content {
  id              String            @id @default(cuid())
  userId          String
  teamId          String?
  title           String
  content         String            @db.Text
  excerpt         String?
  status          ContentStatus     @default(DRAFT)
  publishedAt     DateTime?
  metadata        Json?             // カスタムメタデータ
  tags            String[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  user            User              @relation(fields: [userId], references: [id])
  team            Team?             @relation(fields: [teamId], references: [id])
  versions        ContentVersion[]
  socialPosts     SocialPost[]
  contentMedia    ContentMedia[]
  
  @@index([status, publishedAt])
  @@index([userId, status])
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

// コンテンツバージョン管理
model ContentVersion {
  id          String   @id @default(cuid())
  contentId   String
  userId      String
  version     Int
  title       String
  content     String   @db.Text
  changes     Json?    // 変更差分
  createdAt   DateTime @default(now())
  
  // Relations
  originalContent Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user            User    @relation(fields: [userId], references: [id])
  
  @@unique([contentId, version])
  @@index([contentId, createdAt])
}

// メディアファイル管理
model ContentMedia {
  id          String      @id @default(cuid())
  contentId   String?
  url         String
  type        MediaType
  mimeType    String
  size        Int
  metadata    Json?       // 画像のサイズ、動画の長さなど
  uploadedAt  DateTime    @default(now())
  
  // Relations
  content     Content?    @relation(fields: [contentId], references: [id], onDelete: SetNull)
  socialPosts SocialPostMedia[]
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// SNS投稿管理
model SocialPost {
  id              String            @id @default(cuid())
  userId          String
  teamId          String?
  contentId       String?
  socialAccountId String
  platform        SocialPlatform
  platformPostId  String?           // 各プラットフォームでの投稿ID
  content         String            @db.Text
  hashtags        String[]
  status          PostStatus        @default(DRAFT)
  scheduledFor    DateTime?
  publishedAt     DateTime?
  failedAt        DateTime?
  failureReason   String?
  retryCount      Int               @default(0)
  metadata        Json?             // プラットフォーム固有のデータ
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  user            User              @relation(fields: [userId], references: [id])
  team            Team?             @relation(fields: [teamId], references: [id])
  sourceContent   Content?          @relation(fields: [contentId], references: [id], onDelete: SetNull)
  socialAccount   SocialAccount     @relation(fields: [socialAccountId], references: [id])
  media           SocialPostMedia[]
  metrics         PostMetrics[]
  
  @@index([platform, status, scheduledFor])
  @@index([userId, status])
  @@index([platformPostId, platform])
}

enum PostStatus {
  DRAFT
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  DELETED
}

// SNS投稿メディア
model SocialPostMedia {
  id            String       @id @default(cuid())
  socialPostId  String
  mediaId       String
  order         Int          @default(0)
  
  // Relations
  socialPost    SocialPost   @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  media         ContentMedia @relation(fields: [mediaId], references: [id])
  
  @@unique([socialPostId, mediaId])
  @@index([socialPostId, order])
}

// 投稿メトリクス
model PostMetrics {
  id            String      @id @default(cuid())
  socialPostId  String
  likes         Int         @default(0)
  comments      Int         @default(0)
  shares        Int         @default(0)
  views         Int         @default(0)
  impressions   Int         @default(0)
  reach         Int         @default(0)
  engagement    Float       @default(0)
  saves         Int         @default(0) // Instagram用
  capturedAt    DateTime    @default(now())
  
  // Relations
  socialPost    SocialPost  @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  
  @@index([socialPostId, capturedAt])
}

// 分析データ
model AnalyticsData {
  id            String          @id @default(cuid())
  userId        String
  platform      SocialPlatform?
  metric        String          // followers, engagement_rate, etc.
  value         Float
  metadata      Json?           // 詳細データ
  period        AnalyticsPeriod
  periodStart   DateTime
  periodEnd     DateTime
  capturedAt    DateTime        @default(now())
  
  // Relations
  user          User            @relation(fields: [userId], references: [id])
  
  @@index([userId, platform, metric, periodStart])
  @@index([platform, metric, capturedAt])
}

enum AnalyticsPeriod {
  HOUR
  DAY
  WEEK
  MONTH
  YEAR
}

// n8nワークフロー管理
model N8nWorkflow {
  id            String        @id @default(cuid())
  userId        String
  name          String
  description   String?
  webhookUrl    String
  events        String[]      // イベントタイプの配列
  isActive      Boolean       @default(true)
  metadata      Json?         // カスタム設定
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  user          User          @relation(fields: [userId], references: [id])
  
  @@index([userId, isActive])
}

// Dify設定（ユーザー単位）
model DifyConfig {
  id            String        @id @default(cuid())
  userId        String        @unique
  apiKey        String        @db.Text
  baseUrl       String
  appId         String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// 監査ログ
model AuditLog {
  id            String        @id @default(cuid())
  userId        String
  action        String        // CREATE_CONTENT, PUBLISH_POST, etc.
  entityType    String        // Content, SocialPost, etc.
  entityId      String
  changes       Json?         // 変更内容
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime      @default(now())
  
  // Relations
  user          User          @relation(fields: [userId], references: [id])
  
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

// ジョブキュー（Bullの補完）
model QueueJob {
  id            String        @id @default(cuid())
  jobId         String        @unique
  type          String        // POST_SOCIAL, ANALYZE_METRICS, etc.
  data          Json
  status        JobStatus
  attempts      Int           @default(0)
  error         String?
  result        Json?
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([type, status])
  @@index([scheduledAt, status])
}

enum JobStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
  DELAYED
  PAUSED
}