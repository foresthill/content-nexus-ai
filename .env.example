# Copy this file to .env.local and fill in your values

# Twitter/X API Keys
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Instagram API Keys
# Requires Facebook App: https://developers.facebook.com/apps/
# Enable Instagram Basic Display or Instagram Graph API
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# TikTok API Keys
# Get from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# Redis Configuration
# For local development: brew install redis (Mac) or use Docker
# For production: Use Redis Cloud, AWS ElastiCache, etc.
REDIS_URL=redis://localhost:6379

# JWT Secret
# Generate secure random string: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here

# API Base URL
# Change this for production deployment
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Dify Configuration (configured in-app at /settings/dify)
# DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxx
# DIFY_BASE_URL=https://api.dify.ai/v1

# Optional: n8n Configuration (configured in-app at /settings/n8n)
# N8N_BASE_URL=https://your-n8n-instance.com
# N8N_API_KEY=your_n8n_api_key

# PostgreSQL Database (Neon)
# Get from: https://console.neon.tech/
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Direct connection for migrations (without connection pooling)
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"